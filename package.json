{
  "name": "deep-obsidian-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Filesystem-first MCP server for deep Obsidian vault access, search, chunking, and related-note discovery.",
  "bin": {
    "deep-obsidian-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/index.ts --transport http",
    "check": "tsc --noEmit -p tsconfig.json",
    "verify:config": "node scripts/verify-config-contract.mjs",
    "verify:fixtures": "node scripts/verify-fixture-vault.mjs",
    "verify:http": "node scripts/verify-service-http.mjs",
    "verify:launch": "node scripts/verify-service-launch.mjs",
    "verify:rust": "node scripts/verify-rust-prototype.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "sqlite-vec": "^0.1.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
