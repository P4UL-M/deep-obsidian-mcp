{
  "cases": [
    {
      "name": "cli overrides config, env, and defaults",
      "defaults": {
        "vaultPath": "/default/vault",
        "indexDir": "/default/index",
        "transport": "stdio",
        "stdioMode": "auto",
        "http": {
          "host": "127.0.0.1",
          "port": 4100,
          "mcpPath": "/mcp",
          "healthPath": "/healthz"
        },
        "autoReindex": {
          "enabled": true,
          "debounceMs": 1500,
          "intervalMs": 30000
        },
        "embedding": {
          "provider": null,
          "model": null,
          "baseUrl": null,
          "apiKeyEnv": null
        }
      },
      "env": {
        "OBSIDIAN_VAULT_PATH": "/env/vault",
        "MCP_TRANSPORT_MODE": "stdio",
        "MCP_HTTP_HOST": "0.0.0.0",
        "MCP_HTTP_PORT": "4101",
        "MCP_HTTP_PATH": "/env-mcp",
        "MCP_HTTP_HEALTH_PATH": "/env-health",
        "AUTO_REINDEX": "false",
        "REINDEX_DEBOUNCE_MS": "2000",
        "REINDEX_INTERVAL_MS": "60000",
        "EMBEDDING_MODEL": "text-embedding-3-small",
        "OPENAI_BASE_URL": "https://api.openai.com/v1",
        "OPENAI_API_KEY": "env-openai-key"
      },
      "config": {
        "vaultPath": "/config/vault",
        "indexDir": "/config/index",
        "transport": "http",
        "stdioMode": "newline",
        "http": {
          "host": "0.0.0.0",
          "port": 4111,
          "mcpPath": "/rpc",
          "healthPath": "/live"
        },
        "autoReindex": {
          "enabled": true,
          "debounceMs": 2500,
          "intervalMs": 70000
        },
        "embedding": {
          "provider": "openai-compatible",
          "model": "text-embedding-3-large",
          "baseUrl": "https://api.example.com/v1",
          "apiKeyEnv": "OPENAI_API_KEY"
        }
      },
      "cli": {
        "vaultPath": "/cli/vault",
        "http": {
          "port": 4122,
          "healthPath": "/ready"
        },
        "autoReindex": {
          "enabled": false
        }
      },
      "expected": {
        "vaultPath": "/cli/vault",
        "indexDir": "/config/index",
        "transport": "http",
        "stdioMode": "newline",
        "http": {
          "host": "0.0.0.0",
          "port": 4122,
          "mcpPath": "/rpc",
          "healthPath": "/ready"
        },
        "autoReindex": {
          "enabled": false,
          "debounceMs": 2500,
          "intervalMs": 70000
        },
        "embedding": {
          "provider": "openai-compatible",
          "model": "text-embedding-3-large",
          "baseUrl": "https://api.example.com/v1",
          "apiKeyEnv": "OPENAI_API_KEY"
        }
      }
    }
  ]
}
